# ── Credentials ──────────────────────────────────────────────────────────────
# database.php contains DB credentials (even as env-var fallbacks).
# Never commit it; each environment maintains its own copy.
config/database.php
**/database.php

# ── Logs ─────────────────────────────────────────────────────────────────────
# Log files contain stack traces, usernames, SQL fragments, and file paths.
/logs/
/storage/logs/
*.log

# ── Environment files ────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Dependencies ─────────────────────────────────────────────────────────────
# vendor/ is intentionally committed: production is shared hosting with no
# Composer, so the PHPMailer library must ship with the code.

# ── Database dumps ───────────────────────────────────────────────────────────
*.sql
*.sql.gz

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.claude/
.idea/
.vscode/
*.DS_Store
Thumbs.db
