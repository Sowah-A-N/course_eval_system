# Deny all direct HTTP access to this directory.
#
# PHP files in /config/ execute fine when included by other scripts, but no
# browser request should ever reach them directly (credentials, constants).
# Apache 2.2 syntax:
#   Order deny,allow
#   Deny from all
# Apache 2.4+ syntax (used here — WAMP bundles Apache 2.4):
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
# Fallback for Apache 2.2
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
